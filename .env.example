# Copy to .env and adjust. Every service is bound to 127.0.0.1 — never edit that binding
# to make the stack reachable from the network (see PRD section 13).

# --- Ports published on the host (127.0.0.1 only) ---
API_PORT=8000
FRONTEND_PORT=3000
DB_PORT=5432
REDIS_PORT=6379

# --- Postgres ---
POSTGRES_USER=pcb_inspect
POSTGRES_PASSWORD=pcb_inspect
POSTGRES_DB=pcb_inspect

# --- Backend ---
# Signs session tokens (section 13) — use a random value at least 32 characters long,
# e.g. `openssl rand -hex 32`.
SECRET_KEY=change-me-to-a-random-value
DATABASE_URL=postgresql+asyncpg://pcb_inspect:pcb_inspect@db:5432/pcb_inspect
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Local filesystem paths, as seen *inside* the containers. WATCH_ROOT is mounted read-only;
# APP_DATA_DIR (database volume, annotated images, reports, exports) is writable.
WATCH_ROOT=/data/watch-root
APP_DATA_DIR=/data/app-data

# Host-side paths bind-mounted into the containers above — point these at real directories
# on the machine running the inspection station.
WATCH_ROOT_HOST_PATH=./data/watch-root
APP_DATA_HOST_PATH=./data/app-data

# LLM — local-first by default (LM Studio/Ollama). Only set an API key if opting into a
# cloud provider (PRD section 5.2); this is never required to run the project locally.
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=http://host.docker.internal:1234/v1
LLM_MODEL=local-model
LLM_API_KEY=
LLM_TIMEOUT_S=60

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# Origins allowed to call the API from a browser (comma-separated) — the frontend is a
# separate origin from the API even though both are localhost-only (section 13).
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
